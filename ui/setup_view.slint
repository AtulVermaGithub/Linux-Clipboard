// linux-clipboard SetupView component
// Handles user onboarding and 3 instant one-click hotkey fixers.

export component SetupView inherits VerticalLayout {
    // State properties
    in-out property <int> setup-step;
    in-out property <string> shortcut-status;
    in-out property <string> shortcut-details;
    
    in-out property <string> status-v: "⚡ Fix Alt+V";
    in-out property <string> status-period: "⚡ Fix Alt+.";
    in-out property <string> status-ocr: "⚡ Fix Alt+Shift+T";

    // Styling properties passed from parent
    in property <color> text-color;
    in property <color> text-secondary;
    in property <color> accent-color;
    in property <color> card-bg;
    in property <color> card-hover-bg;
    in property <color> border-color;

    // Callbacks
    callback check-shortcuts();
    callback fix-shortcuts();
    callback fix-single-shortcut(string);
    callback finish-setup();

    padding: 16px;
    spacing: 12px;
    alignment: center;
    
    Text {
        text: "Linux Clipboard Hotkey Setup";
        font-size: 16px;
        font-weight: 700;
        color: text-color;
        horizontal-alignment: center;
    }

    Text {
        text: "Click any button below to instantly bind or fix its global shortcut on your system:";
        font-size: 11px;
        color: text-secondary;
        wrap: word-wrap;
        horizontal-alignment: center;
    }

    // 1. Alt + V Card
    Rectangle {
        background: card-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: border-color;

        HorizontalLayout {
            padding: 10px;
            alignment: space-between;

            VerticalLayout {
                spacing: 2px;
                Text {
                    text: "📋 Clipboard History";
                    font-size: 12px;
                    font-weight: 700;
                    color: text-color;
                }
                Text {
                    text: "Hotkey: Alt + V";
                    font-size: 11px;
                    color: accent-color;
                    font-weight: 600;
                }
            }

            TouchArea {
                width: 120px;
                height: 30px;
                clicked => {
                    fix-single-shortcut("toggle");
                    status-v = "✓ Active";
                }
                Rectangle {
                    background: status-v == "✓ Active" ? #107c41 : accent-color;
                    border-radius: 6px;
                    Text {
                        text: status-v;
                        color: #ffffff;
                        font-size: 11px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // 2. Alt + . Card
    Rectangle {
        background: card-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: border-color;

        HorizontalLayout {
            padding: 10px;
            alignment: space-between;

            VerticalLayout {
                spacing: 2px;
                Text {
                    text: "😀 Emoji Picker";
                    font-size: 12px;
                    font-weight: 700;
                    color: text-color;
                }
                Text {
                    text: "Hotkey: Alt + .";
                    font-size: 11px;
                    color: accent-color;
                    font-weight: 600;
                }
            }

            TouchArea {
                width: 120px;
                height: 30px;
                clicked => {
                    fix-single-shortcut("emoji");
                    status-period = "✓ Active";
                }
                Rectangle {
                    background: status-period == "✓ Active" ? #107c41 : accent-color;
                    border-radius: 6px;
                    Text {
                        text: status-period;
                        color: #ffffff;
                        font-size: 11px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // 3. Alt + Shift + T Card
    Rectangle {
        background: card-bg;
        border-radius: 8px;
        border-width: 1px;
        border-color: border-color;

        HorizontalLayout {
            padding: 10px;
            alignment: space-between;

            VerticalLayout {
                spacing: 2px;
                Text {
                    text: "🔍 Text Extractor (OCR)";
                    font-size: 12px;
                    font-weight: 700;
                    color: text-color;
                }
                Text {
                    text: "Hotkey: Alt + Shift + T";
                    font-size: 11px;
                    color: accent-color;
                    font-weight: 600;
                }
            }

            TouchArea {
                width: 135px;
                height: 30px;
                clicked => {
                    fix-single-shortcut("ocr");
                    status-ocr = "✓ Active";
                }
                Rectangle {
                    background: status-ocr == "✓ Active" ? #107c41 : accent-color;
                    border-radius: 6px;
                    Text {
                        text: status-ocr;
                        color: #ffffff;
                        font-size: 11px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // Finish Setup Button
    TouchArea {
        height: 34px;
        clicked => {
            finish-setup();
        }
        Rectangle {
            background: #107c41;
            border-radius: 6px;
            Text {
                text: "Done - Open Clipboard History";
                color: #ffffff;
                font-weight: 700;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
