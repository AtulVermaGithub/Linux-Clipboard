// linux-clipboard SetupView component
// Handles first-run user onboarding, conflict detection, auto-resolution, and manual hotkey binding instructions.

export component SetupView inherits VerticalLayout {
    // State properties
    in-out property <int> setup-step;
    in-out property <string> shortcut-status;
    in-out property <string> shortcut-details;

    // Styling properties passed from parent
    in property <color> text-color;
    in property <color> text-secondary;
    in property <color> accent-color;
    in property <color> card-bg;
    in property <color> border-color;

    // Callbacks
    callback check-shortcuts();
    callback fix-shortcuts();
    callback finish-setup();

    padding: 18px;
    spacing: 16px;
    alignment: center;
    
    Text {
        text: "Linux Clipboard Setup";
        font-size: 18px;
        font-weight: 700;
        color: text-color;
        horizontal-alignment: center;
    }

    // SCREEN 0: Welcome & Initial Detect
    if (setup-step == 0) : VerticalLayout {
        spacing: 14px;
        Text {
            text: "Configure global hotkeys so you can access your clipboard history instantly at any time.";
            font-size: 12px;
            color: text-secondary;
            wrap: word-wrap;
            horizontal-alignment: center;
        }
        Text {
            text: "Default Hotkey: Super + V";
            font-size: 13px;
            font-weight: 600;
            color: accent-color;
            horizontal-alignment: center;
        }
        TouchArea {
            height: 38px;
            clicked => {
                check-shortcuts();
            }
            Rectangle {
                background: accent-color;
                border-radius: 6px;
                Text {
                    text: "Check Hotkey Availability";
                    color: #ffffff;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }

    // SCREEN 1: Checking, Conflict, or Success Details
    if (setup-step == 1) : VerticalLayout {
        spacing: 14px;
        
        if (shortcut-status == "checking") : VerticalLayout {
            alignment: center;
            spacing: 8px;
            Text {
                text: "Scanning system shortcuts...";
                font-size: 13px;
                color: text-color;
                horizontal-alignment: center;
            }
        }

        if (shortcut-status == "conflict") : VerticalLayout {
            spacing: 12px;
            Text {
                text: "⚠️ Hotkey Conflict Detected!";
                font-size: 13px;
                font-weight: 600;
                color: #d83b01; // Red warning color
                horizontal-alignment: center;
            }
            Rectangle {
                background: card-bg;
                border-radius: 6px;
                border-width: 1px;
                border-color: border-color;
                VerticalLayout {
                    padding: 10px;
                    spacing: 4px;
                    Text {
                        text: "Super+V is currently registered to:";
                        font-size: 11px;
                        color: text-secondary;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: shortcut-details;
                        font-size: 12px;
                        font-weight: 700;
                        color: text-color;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }
            Text {
                text: "Clicking 'Resolve & Fix' will disable the conflicting shortcut and bind Super+V to Linux Clipboard.";
                font-size: 11px;
                color: text-secondary;
                wrap: word-wrap;
                horizontal-alignment: center;
            }
            TouchArea {
                height: 38px;
                clicked => {
                    fix-shortcuts();
                }
                Rectangle {
                    background: accent-color;
                    border-radius: 6px;
                    Text {
                        text: "Resolve & Fix Shortcut";
                        color: #ffffff;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        if (shortcut-status == "ok") : VerticalLayout {
            spacing: 12px;
            Text {
                text: "✓ Hotkeys Configured Successfully!";
                font-size: 13px;
                font-weight: 600;
                color: #107c41; // Green color
                horizontal-alignment: center;
            }
            Text {
                text: "Super + V is now active for Clipboard History.\nSuper + . is active for Emojis.";
                font-size: 12px;
                color: text-secondary;
                horizontal-alignment: center;
            }
            TouchArea {
                height: 38px;
                clicked => {
                    finish-setup();
                }
                Rectangle {
                    background: #107c41;
                    border-radius: 6px;
                    Text {
                        text: "Start Using Clipboard";
                        color: #ffffff;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        if (shortcut-status == "failed") : VerticalLayout {
            spacing: 12px;
            Text {
                text: "❌ Auto-configuration Failed";
                font-size: 13px;
                font-weight: 600;
                color: #d83b01;
                horizontal-alignment: center;
            }
            Text {
                text: "We could not automatically bind the hotkeys on your current desktop configuration.";
                font-size: 12px;
                color: text-secondary;
                wrap: word-wrap;
                horizontal-alignment: center;
            }
            TouchArea {
                height: 38px;
                clicked => {
                    setup-step = 2;
                }
                Rectangle {
                    background: accent-color;
                    border-radius: 6px;
                    Text {
                        text: "Show Manual Setup Guide";
                        color: #ffffff;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // SCREEN 2: Manual Instructions
    if (setup-step == 2) : VerticalLayout {
        spacing: 12px;
        Text {
            text: "Manual Hotkey Configuration";
            font-size: 13px;
            font-weight: 600;
            color: text-color;
            horizontal-alignment: center;
        }
        Rectangle {
            background: card-bg;
            border-radius: 6px;
            border-width: 1px;
            border-color: border-color;
            VerticalLayout {
                padding: 10px;
                spacing: 6px;
                Text {
                    text: "1. Open your desktop Settings -> Keyboard Shortcuts.";
                    font-size: 11px;
                    color: text-color;
                }
                Text {
                    text: "2. Add a Custom Shortcut:";
                    font-size: 11px;
                    color: text-color;
                    font-weight: 600;
                }
                Text {
                    text: "   • Name: Linux Clipboard\n   • Command: lincb.ople.in\n   • Shortcut: Super + V";
                    font-size: 11px;
                    color: text-color;
                }
            }
        }
        TouchArea {
            height: 38px;
            clicked => {
                finish-setup();
            }
            Rectangle {
                background: accent-color;
                border-radius: 6px;
                Text {
                    text: "Completed - Open Clipboard";
                    color: #ffffff;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
