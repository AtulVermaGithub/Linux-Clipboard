// linux-clipboard Slint UI file
// Implements the layout, visual styling, tabs, search, and action callbacks.

import { ScrollView } from "std-widgets.slint";

import { SlintClipItem, SlintEmojiItem, SlintEmojiRow } from "./types.slint";
import { HistoryCard } from "./history_card.slint";
import { SetupView } from "./setup_view.slint";
import { EmojiPanel } from "./emoji_panel.slint";
import { PreferencesPanel } from "./preferences_panel.slint";

export component AppWindow inherits Window {
    // Window properties
    title: "Clipboard History";
    width: 360px;
    height: 480px;
    always-on-top: true;
    background: transparent;
    no-frame: true;

    // Callbacks to Rust backend
    callback paste-item(string);         // item ID
    callback delete-item(string);        // item ID
    callback toggle-pin(string);         // item ID
    callback clear-history();
    callback record-emoji(string);       // emoji char
    callback search-changed(string);     // search text
    callback emoji-category-changed(int); // category index
    callback change-theme(string);
    callback toggle-ocr(bool);
    callback open-setup();
    callback close-window();
    callback check-shortcuts();
    callback fix-shortcuts();
    callback fix-single-shortcut(string);
    callback finish-setup();

    // Data models populated by Rust
    in-out property <[SlintClipItem]> clips: [];
    in-out property <[SlintEmojiRow]> emoji_rows: [];
    in-out property <int> selected_index: 0;
    in-out property <int> active-tab: 0; // 0 = Clips, 1 = Emojis, 2 = GIFs/Kaomojis
    in-out property <int> active-emoji-category: 0; // 0-8 for emoji categories
    in-out property <bool> is-dark: true;
    in-out property <bool> enable-ocr: true;
    in-out property <bool> show-setup: false;
    in-out property <int> setup-step: 0; // 0 = Welcome, 1 = Detect/Conflict, 2 = Manual Setup
    in-out property <string> shortcut-status: "detecting"; // "detecting", "conflict", "ok", "failed"
    in-out property <string> shortcut-details: "";
    in-out property <string> search-placeholder: "Search clipboard...";
    in-out property <string> search-text: "";
    in-out property <string> theme-mode: "system";


    // Dynamic coloring tokens
    property <color> bg-color: is-dark ? #202020 : #f3f3f3;
    property <color> border-color: is-dark ? #303030 : #e0e0e0;
    property <color> text-color: is-dark ? #ffffff : #1c1c1c;
    property <color> text-secondary: is-dark ? #aaaaaa : #666666;
    property <color> accent-color: #0078d4; // Windows Blue accent
    property <color> card-bg: is-dark ? #2d2d2d : #ffffff;
    property <color> card-hover-bg: is-dark ? #3d3d3d : #f9f9f9;
    property <color> pinned-color: is-dark ? #ffb900 : #d83b01;
    property <color> pinned-bg: is-dark ? rgba(255, 185, 0, 0.08) : rgba(216, 59, 1, 0.06);

    in-out property <length> scroll-y: 0px;

    function scroll-to-index(idx: int) {
        let has-pinned: bool = root.clips.length > 0 && root.clips[0].pinned;
        let is-past-pinned: bool = idx > 0 && !root.clips[idx].pinned && has-pinned;
        let item-top: length = idx * 76px + (has-pinned ? (is-past-pinned ? 44px : 22px) : 22px);
        let item-bottom: length = item-top + 70px;
        let view-top = -scroll-y;
        let view-bottom = -scroll-y + 330px;
        
        if (item-top < view-top) {
            scroll-y = -item-top;
        } else if (item-bottom > view-bottom) {
            scroll-y = -(item-bottom - 330px);
        }
    }

    changed selected_index => {
        root.scroll-to-index(self.selected_index);
    }

    public function reset-state() {
        root.search-text = "";
        root.selected_index = 0;
        root.scroll-y = 0px;
        root.active-tab = 0;
        root.active-emoji-category = 0;
        root.search-placeholder = "Search history...";
        root.search-changed("");
    }

    // Main layout container with rounded border
    FocusScope {
        width: 100%;
        height: 100%;
        
        Rectangle {
            width: 100%;
            height: 100%;
            background: bg-color;
            border-radius: 12px;
            border-width: 1px;
            border-color: border-color;
            clip: true;

            if (show-setup) : SetupView {
                setup-step <=> root.setup-step;
                shortcut-status <=> root.shortcut-status;
                shortcut-details <=> root.shortcut-details;
                text-color: root.text-color;
                text-secondary: root.text-secondary;
                accent-color: root.accent-color;
                card-bg: root.card-bg;
                border-color: root.border-color;
                
                check-shortcuts() => { root.check-shortcuts(); }
                fix-shortcuts() => { root.fix-shortcuts(); }
                fix-single-shortcut(sc) => { root.fix-single-shortcut(sc); }
                finish-setup() => { root.finish-setup(); }
            }

            if (!show-setup) : VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Header section
                HorizontalLayout {
                    z: 10;
                    alignment: space-between;
                    
                    Text {
                        text: "Clipboard";
                        font-size: 16px;
                        font-weight: 700;
                        color: text-color;
                        vertical-alignment: center;
                    }
                    
                    HorizontalLayout {
                        spacing: 8px;
                        
                        // Clear All button
                        clear-all-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.clear-history(); }
                            
                            Rectangle {
                                background: clear-all-btn.has-hover ? card-hover-bg : transparent;
                                border-radius: 4px;
                                
                                // Custom Vector-drawn Red Trashcan Icon
                                Rectangle {
                                    width: 12px;
                                    height: 14px;
                                    
                                    VerticalLayout {
                                        spacing: 1px;
                                        alignment: center;
                                        
                                        // Lid handle
                                        Rectangle {
                                            width: 4px;
                                            height: 1.5px;
                                            background: #ff3b30;
                                            border-radius: 0.5px;
                                        }
                                        
                                        // Lid
                                        Rectangle {
                                            width: 12px;
                                            height: 1.5px;
                                            background: #ff3b30;
                                            border-radius: 0.5px;
                                        }
                                        
                                        // Can body
                                        Rectangle {
                                            width: 10px;
                                            height: 9px;
                                            border-width: 1.2px;
                                            border-color: #ff3b30;
                                            border-radius: 1px;
                                            
                                            // Ribs
                                            HorizontalLayout {
                                                alignment: space-around;
                                                padding-left: 1.5px;
                                                padding-right: 1.5px;
                                                Rectangle { width: 1px; height: 5px; background: #ff3b30; }
                                                Rectangle { width: 1px; height: 5px; background: #ff3b30; }
                                            }
                                        }
                                    }
                                }
                            }
                            
                            if (clear-all-btn.has-hover) : Rectangle {
                                x: -80px;
                                y: 28px;
                                width: 96px;
                                height: 20px;
                                background: card-bg;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: border-color;
                                z: 100;
                                
                                Text {
                                    text: "Clear clipboard";
                                    font-size: 10px;
                                    color: text-color;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Preferences Button
                        pref-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { active-tab = 2; }
                            
                            Rectangle {
                                background: pref-btn.has-hover ? card-hover-bg : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "☰";
                                    font-size: 13px;
                                    color: text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            
                            if (pref-btn.has-hover) : Rectangle {
                                x: -60px;
                                y: 28px;
                                width: 80px;
                                height: 20px;
                                background: card-bg;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: border-color;
                                z: 100;
                                
                                Text {
                                    text: "Preferences";
                                    font-size: 10px;
                                    color: text-color;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Close button
                        close-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.close-window(); }
                            
                            Rectangle {
                                background: close-btn.has-hover ? #e81123 : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "✕";
                                    font-size: 12px;
                                    color: close-btn.has-hover ? #ffffff : text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                              HorizontalLayout {
                    height: 36px;
                    spacing: 4px;
                    
                    // Tab 1: Clipboard
                    TouchArea {
                        clicked => {
                            active-tab = 0;
                            search-placeholder = "Search history...";
                            root.search-text = "";
                            root.search-changed("");
                        }
                        Rectangle {
                            background: active-tab == 0 ? card-bg : (parent.has-hover ? card-hover-bg : bg-color);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: active-tab == 0 ? accent-color : border-color;
                            Text {
                                text: "🕒 History";
                                font-weight: 600;
                                color: active-tab == 0 ? accent-color : text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Tab 2: Emojis
                    TouchArea {
                        clicked => {
                            active-tab = 1;
                            search-placeholder = "Search emojis...";
                            root.search-text = "";
                            root.search-changed("");
                            root.active-emoji-category = 0;
                            root.emoji-category-changed(0);
                        }
                        Rectangle {
                            background: active-tab == 1 ? card-bg : (parent.has-hover ? card-hover-bg : bg-color);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: active-tab == 1 ? accent-color : border-color;
                            Text {
                                text: "😊 Emojis";
                                font-weight: 600;
                                color: active-tab == 1 ? accent-color : text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Search Bar Container
                if (active-tab != 2) : Rectangle {
                    height: 36px;
                    background: card-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: border-color;
                    
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        alignment: stretch;
                        
                        search-input := TextInput {
                            text <=> root.search-text;
                            font-size: 13px;
                            color: text-color;
                            single-line: true;
                            vertical-alignment: center;
                            
                            init => { self.focus(); }
                            
                            // Connect input edits back to search filter
                            edited => { root.search-changed(self.text); }
                            
                            // Intercept arrow keys and enter
                            key-pressed(event) => {
                                if (event.text == Key.DownArrow) {
                                    root.selected_index = Math.min(root.selected_index + 1, root.clips.length - 1);
                                    return accept;
                                }
                                if (event.text == Key.UpArrow) {
                                    root.selected_index = Math.max(root.selected_index - 1, 0);
                                    return accept;
                                }
                                if (event.text == Key.Return) {
                                    if (root.clips.length > 0 && root.selected_index >= 0 && root.selected_index < root.clips.length) {
                                        root.paste-item(root.clips[root.selected_index].id);
                                    }
                                    return accept;
                                }
                                reject
                            }
                            
                            // Placeholder Text
                            if (self.text == "") : Text {
                                text: search-placeholder;
                                font-size: 13px;
                                color: text-secondary;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
 
                 // Main tab layouts viewport
                 if (active-tab == 0) : ScrollView {
                     viewport-y <=> root.scroll-y;
                     
                     VerticalLayout {
                         alignment: start;
                         spacing: 6px;
                         padding-right: 4px;
                         
                         for clip[idx] in clips : VerticalLayout {
                             spacing: 4px;
                             
                             if (idx == 0 && clip.pinned) : HorizontalLayout {
                                 padding-left: 6px;
                                 padding-top: 2px;
                                 padding-bottom: 2px;
                                 Text {
                                     text: "📌 Pinned";
                                     font-size: 11px;
                                     font-weight: 700;
                                     color: pinned-color;
                                 }
                             }
                             
                             if (!clip.pinned && (idx == 0 || root.clips[idx - 1].pinned)) : HorizontalLayout {
                                 padding-left: 6px;
                                 padding-top: 6px;
                                 padding-bottom: 2px;
                                 Text {
                                     text: "📋 Recent";
                                     font-size: 11px;
                                     font-weight: 700;
                                     color: text-secondary;
                                 }
                             }

                             HistoryCard {
                                 item: clip;
                                 is-selected: root.selected_index == idx;
                                 bg-color: root.bg-color;
                                 border-color: root.border-color;
                                 text-color: root.text-color;
                                 text-secondary: root.text-secondary;
                                 accent-color: root.accent-color;
                                 card-bg: root.card-bg;
                                 card-hover-bg: root.card-hover-bg;
                                 pinned-bg: root.pinned-bg;
                                 
                                 paste-item(id) => { root.paste-item(id); }
                                 toggle-pin(id) => { root.toggle-pin(id); }
                                 delete-item(id) => { root.delete-item(id); }
                             }
                         }
                     }
                 }
                 if (active-tab == 1) : EmojiPanel {
                     active-emoji-category <=> root.active-emoji-category;
                     emoji-rows: root.emoji-rows;
                     card-bg: root.card-bg;
                     card-hover-bg: root.card-hover-bg;
                     border-color: root.border-color;
                     accent-color: root.accent-color;
                     
                     emoji-category-changed(cat) => { root.emoji-category-changed(cat); }
                     record-emoji(emoji) => { root.record-emoji(emoji); }
                 }

                 if (active-tab == 2) : PreferencesPanel {
                     theme-mode <=> root.theme-mode;
                     enable-ocr <=> root.enable-ocr;
                     text-color: root.text-color;
                     text-secondary: root.text-secondary;
                     card-bg: root.card-bg;
                     card-hover-bg: root.card-hover-bg;
                     border-color: root.border-color;
                     accent-color: root.accent-color;
                     
                     change-theme(theme) => { root.change-theme(theme); }
                     toggle-ocr(enabled) => { root.toggle-ocr(enabled); }
                     open-setup() => { root.open-setup(); }
                 }
             }
        }
    }
}
