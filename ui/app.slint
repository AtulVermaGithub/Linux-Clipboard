// linux-clipboard Slint UI file
// Implements the layout, visual styling, tabs, search, and action callbacks.

import { ScrollView } from "std-widgets.slint";

export struct SlintClipItem {
    id: string,
    item_type: string,    // "Text", "RichText", "Image"
    plain_text: string,
    timestamp_str: string,
    pinned: bool,
    preview: string,
    image_base64: string, // Only loaded if type is Image
    image: image,
}

export struct SlintEmojiItem {
    character: string,
    description: string,
}

export struct SlintEmojiRow {
    cols: [SlintEmojiItem],
}

export component AppWindow inherits Window {
    // Window properties
    title: "Clipboard History";
    width: 360px;
    height: 480px;
    always-on-top: true;
    background: transparent;
    no-frame: true;

    // Callbacks to Rust backend
    callback paste-item(string);         // item ID
    callback delete-item(string);        // item ID
    callback toggle-pin(string);         // item ID
    callback clear-history();
    callback record-emoji(string);       // emoji char
    callback search-changed(string);     // search text
    callback emoji-category-changed(int); // category index
    callback open-settings();
    callback change-theme(string);
    callback close-window();
    callback check-shortcuts();
    callback fix-shortcuts();
    callback finish-setup();

    // Data models populated by Rust
    in-out property <[SlintClipItem]> clips: [];
    in-out property <[SlintEmojiRow]> emoji_rows: [];
    in-out property <int> selected_index: 0;
    in-out property <int> active-tab: 0; // 0 = Clips, 1 = Emojis, 2 = GIFs/Kaomojis
    in-out property <int> active-emoji-category: 0; // 0-8 for emoji categories
    in-out property <bool> is-dark: true;
    in-out property <bool> show-setup: false;
    in-out property <int> setup-step: 0; // 0 = Welcome, 1 = Detect/Conflict, 2 = Manual Setup
    in-out property <string> shortcut-status: "detecting"; // "detecting", "conflict", "ok", "failed"
    in-out property <string> shortcut-details: "";
    in-out property <string> search-placeholder: "Search clipboard...";
    in-out property <string> search-text: "";
    in-out property <string> theme-mode: "system";


    // Dynamic coloring tokens
    property <color> bg-color: is-dark ? #202020 : #f3f3f3;
    property <color> border-color: is-dark ? #303030 : #e0e0e0;
    property <color> text-color: is-dark ? #ffffff : #1c1c1c;
    property <color> text-secondary: is-dark ? #aaaaaa : #666666;
    property <color> accent-color: #0078d4; // Windows Blue accent
    property <color> card-bg: is-dark ? #2d2d2d : #ffffff;
    property <color> card-hover-bg: is-dark ? #3d3d3d : #f9f9f9;
    property <color> pinned-color: is-dark ? #ffb900 : #d83b01;
    property <color> pinned-bg: is-dark ? rgba(255, 185, 0, 0.08) : rgba(216, 59, 1, 0.06);

    in-out property <length> scroll-y: 0px;

    function scroll-to-index(idx: int) {
        let has-pinned: bool = root.clips.length > 0 && root.clips[0].pinned;
        let is-past-pinned: bool = idx > 0 && !root.clips[idx].pinned && has-pinned;
        let item-top: length = idx * 76px + (has-pinned ? (is-past-pinned ? 44px : 22px) : 22px);
        let item-bottom: length = item-top + 70px;
        let view-top = -scroll-y;
        let view-bottom = -scroll-y + 330px;
        
        if (item-top < view-top) {
            scroll-y = -item-top;
        } else if (item-bottom > view-bottom) {
            scroll-y = -(item-bottom - 330px);
        }
    }

    changed selected_index => {
        root.scroll-to-index(self.selected_index);
    }

    public function reset-state() {
        root.search-text = "";
        root.selected_index = 0;
        root.scroll-y = 0px;
        root.active-tab = 0;
        root.active-emoji-category = 0;
        root.search-placeholder = "Search history...";
        root.search-changed("");
    }

    // Main layout container with rounded border
    FocusScope {
        width: 100%;
        height: 100%;
        
        Rectangle {
            width: 100%;
            height: 100%;
            background: bg-color;
            border-radius: 12px;
            border-width: 1px;
            border-color: border-color;
            clip: true;

            if (show-setup) : VerticalLayout {
                padding: 18px;
                spacing: 16px;
                alignment: center;
                
                Text {
                    text: "Linux Clipboard Setup";
                    font-size: 18px;
                    font-weight: 700;
                    color: text-color;
                    horizontal-alignment: center;
                }

                // SCREEN 0: Welcome & Initial Detect
                if (setup-step == 0) : VerticalLayout {
                    spacing: 14px;
                    Text {
                        text: "Configure global hotkeys so you can access your clipboard history instantly at any time.";
                        font-size: 12px;
                        color: text-secondary;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Default Hotkey: Super + V";
                        font-size: 13px;
                        font-weight: 600;
                        color: accent-color;
                        horizontal-alignment: center;
                    }
                    TouchArea {
                        height: 38px;
                        clicked => {
                            root.check-shortcuts();
                        }
                        Rectangle {
                            background: accent-color;
                            border-radius: 6px;
                            Text {
                                text: "Check Hotkey Availability";
                                color: #ffffff;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // SCREEN 1: Checking, Conflict, or Success Details
                if (setup-step == 1) : VerticalLayout {
                    spacing: 14px;
                    
                    if (shortcut-status == "checking") : VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "Scanning system shortcuts...";
                            font-size: 13px;
                            color: text-color;
                            horizontal-alignment: center;
                        }
                    }

                    if (shortcut-status == "conflict") : VerticalLayout {
                        spacing: 12px;
                        Text {
                            text: "⚠️ Hotkey Conflict Detected!";
                            font-size: 13px;
                            font-weight: 600;
                            color: #d83b01; // Red warning color
                            horizontal-alignment: center;
                        }
                        Rectangle {
                            background: card-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: border-color;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: "Super+V is currently registered to:";
                                    font-size: 11px;
                                    color: text-secondary;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: shortcut-details;
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: text-color;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                        Text {
                            text: "Clicking 'Resolve & Fix' will disable the conflicting shortcut and bind Super+V to Linux Clipboard.";
                            font-size: 11px;
                            color: text-secondary;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                        }
                        TouchArea {
                            height: 38px;
                            clicked => {
                                root.fix-shortcuts();
                            }
                            Rectangle {
                                background: accent-color;
                                border-radius: 6px;
                                Text {
                                    text: "Resolve & Fix Shortcut";
                                    color: #ffffff;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    if (shortcut-status == "ok") : VerticalLayout {
                        spacing: 12px;
                        Text {
                            text: "✓ Hotkeys Configured Successfully!";
                            font-size: 13px;
                            font-weight: 600;
                            color: #107c41; // Green color
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Super + V is now active for Clipboard History.\nSuper + . is active for Emojis.";
                            font-size: 12px;
                            color: text-secondary;
                            horizontal-alignment: center;
                        }
                        TouchArea {
                            height: 38px;
                            clicked => {
                                root.finish-setup();
                            }
                            Rectangle {
                                background: #107c41;
                                border-radius: 6px;
                                Text {
                                    text: "Start Using Clipboard";
                                    color: #ffffff;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    if (shortcut-status == "failed") : VerticalLayout {
                        spacing: 12px;
                        Text {
                            text: "❌ Auto-configuration Failed";
                            font-size: 13px;
                            font-weight: 600;
                            color: #d83b01;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "We could not automatically bind the hotkeys on your current desktop configuration.";
                            font-size: 12px;
                            color: text-secondary;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                        }
                        TouchArea {
                            height: 38px;
                            clicked => {
                                setup-step = 2;
                            }
                            Rectangle {
                                background: accent-color;
                                border-radius: 6px;
                                Text {
                                    text: "Show Manual Setup Guide";
                                    color: #ffffff;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // SCREEN 2: Manual Instructions
                if (setup-step == 2) : VerticalLayout {
                    spacing: 12px;
                    Text {
                        text: "Manual Hotkey Configuration";
                        font-size: 13px;
                        font-weight: 600;
                        color: text-color;
                        horizontal-alignment: center;
                    }
                    Rectangle {
                        background: card-bg;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: border-color;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;
                            Text {
                                text: "1. Open your desktop Settings -> Keyboard Shortcuts.";
                                font-size: 11px;
                                color: text-color;
                            }
                            Text {
                                text: "2. Add a Custom Shortcut:";
                                font-size: 11px;
                                color: text-color;
                                font-weight: 600;
                            }
                            Text {
                                text: "   • Name: Linux Clipboard\n   • Command: linux-clipboard\n   • Shortcut: Super + V";
                                font-size: 11px;
                                color: text-color;
                            }
                        }
                    }
                    TouchArea {
                        height: 38px;
                        clicked => {
                            root.finish-setup();
                        }
                        Rectangle {
                            background: accent-color;
                            border-radius: 6px;
                            Text {
                                text: "Completed - Open Clipboard";
                                color: #ffffff;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            if (!show-setup) : VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Header section
                HorizontalLayout {
                    z: 10;
                    alignment: space-between;
                    
                    Text {
                        text: "Clipboard";
                        font-size: 16px;
                        font-weight: 700;
                        color: text-color;
                        vertical-alignment: center;
                    }
                    
                    HorizontalLayout {
                        spacing: 8px;
                        
                        // Clear All button
                        clear-all-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.clear-history(); }
                            
                            Rectangle {
                                background: clear-all-btn.has-hover ? card-hover-bg : transparent;
                                border-radius: 4px;
                                
                                // Custom Vector-drawn Red Trashcan Icon
                                Rectangle {
                                    width: 12px;
                                    height: 14px;
                                    
                                    VerticalLayout {
                                        spacing: 1px;
                                        alignment: center;
                                        
                                        // Lid handle
                                        Rectangle {
                                            width: 4px;
                                            height: 1.5px;
                                            background: #ff3b30;
                                            border-radius: 0.5px;
                                        }
                                        
                                        // Lid
                                        Rectangle {
                                            width: 12px;
                                            height: 1.5px;
                                            background: #ff3b30;
                                            border-radius: 0.5px;
                                        }
                                        
                                        // Can body
                                        Rectangle {
                                            width: 10px;
                                            height: 9px;
                                            border-width: 1.2px;
                                            border-color: #ff3b30;
                                            border-radius: 1px;
                                            
                                            // Ribs
                                            HorizontalLayout {
                                                alignment: space-around;
                                                padding-left: 1.5px;
                                                padding-right: 1.5px;
                                                Rectangle { width: 1px; height: 5px; background: #ff3b30; }
                                                Rectangle { width: 1px; height: 5px; background: #ff3b30; }
                                            }
                                        }
                                    }
                                }
                            }
                            
                            if (clear-all-btn.has-hover) : Rectangle {
                                x: -80px;
                                y: 28px;
                                width: 96px;
                                height: 20px;
                                background: card-bg;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: border-color;
                                z: 100;
                                
                                Text {
                                    text: "Clear clipboard";
                                    font-size: 10px;
                                    color: text-color;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Preferences Button
                        pref-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { active-tab = 2; }
                            
                            Rectangle {
                                background: pref-btn.has-hover ? card-hover-bg : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "☰";
                                    font-size: 13px;
                                    color: text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                            
                            if (pref-btn.has-hover) : Rectangle {
                                x: -60px;
                                y: 28px;
                                width: 80px;
                                height: 20px;
                                background: card-bg;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: border-color;
                                z: 100;
                                
                                Text {
                                    text: "Preferences";
                                    font-size: 10px;
                                    color: text-color;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Close button
                        close-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.close-window(); }
                            
                            Rectangle {
                                background: close-btn.has-hover ? #e81123 : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "✕";
                                    font-size: 12px;
                                    color: close-btn.has-hover ? #ffffff : text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                              HorizontalLayout {
                    height: 36px;
                    spacing: 4px;
                    
                    // Tab 1: Clipboard
                    TouchArea {
                        clicked => {
                            active-tab = 0;
                            search-placeholder = "Search history...";
                            root.search-text = "";
                            root.search-changed("");
                        }
                        Rectangle {
                            background: active-tab == 0 ? card-bg : (parent.has-hover ? card-hover-bg : bg-color);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: active-tab == 0 ? accent-color : border-color;
                            Text {
                                text: "🕒 History";
                                font-weight: 600;
                                color: active-tab == 0 ? accent-color : text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Tab 2: Emojis
                    TouchArea {
                        clicked => {
                            active-tab = 1;
                            search-placeholder = "Search emojis...";
                            root.search-text = "";
                            root.search-changed("");
                            root.active-emoji-category = 0;
                            root.emoji-category-changed(0);
                        }
                        Rectangle {
                            background: active-tab == 1 ? card-bg : (parent.has-hover ? card-hover-bg : bg-color);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: active-tab == 1 ? accent-color : border-color;
                            Text {
                                text: "😊 Emojis";
                                font-weight: 600;
                                color: active-tab == 1 ? accent-color : text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Search Bar Container
                if (active-tab != 2) : Rectangle {
                    height: 36px;
                    background: card-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: border-color;
                    
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        alignment: stretch;
                        
                        search-input := TextInput {
                            text <=> root.search-text;
                            font-size: 13px;
                            color: text-color;
                            single-line: true;
                            vertical-alignment: center;
                            
                            init => { self.focus(); }
                            
                            // Connect input edits back to search filter
                            edited => { root.search-changed(self.text); }
                            
                            // Intercept arrow keys and enter
                            key-pressed(event) => {
                                if (event.text == Key.DownArrow) {
                                    root.selected_index = Math.min(root.selected_index + 1, root.clips.length - 1);
                                    return accept;
                                }
                                if (event.text == Key.UpArrow) {
                                    root.selected_index = Math.max(root.selected_index - 1, 0);
                                    return accept;
                                }
                                if (event.text == Key.Return) {
                                    if (root.clips.length > 0 && root.selected_index >= 0 && root.selected_index < root.clips.length) {
                                        root.paste-item(root.clips[root.selected_index].id);
                                    }
                                    return accept;
                                }
                                reject
                            }
                            
                            // Placeholder Text
                            if (self.text == "") : Text {
                                text: search-placeholder;
                                font-size: 13px;
                                color: text-secondary;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
 
                 // Main tab layouts viewport
                 if (active-tab == 0) : ScrollView {
                     viewport-y <=> root.scroll-y;
                     
                     VerticalLayout {
                         alignment: start;
                         spacing: 6px;
                         padding-right: 4px;
                         
                         for clip[idx] in clips : VerticalLayout {
                             spacing: 4px;
                             
                             if (idx == 0 && clip.pinned) : HorizontalLayout {
                                 padding-left: 6px;
                                 padding-top: 2px;
                                 padding-bottom: 2px;
                                 Text {
                                     text: "📌 Pinned";
                                     font-size: 11px;
                                     font-weight: 700;
                                     color: pinned-color;
                                 }
                             }
                             
                             if (!clip.pinned && (idx == 0 || root.clips[idx - 1].pinned)) : HorizontalLayout {
                                 padding-left: 6px;
                                 padding-top: 6px;
                                 padding-bottom: 2px;
                                 Text {
                                     text: "📋 Recent";
                                     font-size: 11px;
                                     font-weight: 700;
                                     color: text-secondary;
                                 }
                             }

                             TouchArea {
                                 height: 70px;
                                 clicked => { root.paste-item(clip.id); }
     
                                 Rectangle {
                                     clip: true;
                                     background: (root.selected_index == idx) ? card-hover-bg : (parent.has-hover ? card-hover-bg : (clip.pinned ? pinned-bg : card-bg));
                                     border-radius: 8px;
                                     border-width: (root.selected_index == idx) ? 1.5px : 1px;
                                     border-color: (root.selected_index == idx) ? accent-color : border-color;
                                     
                                     HorizontalLayout {
                                         padding: 8px;
                                         spacing: 8px;
                                         
                                         if (clip.item_type == "Image") : Image {
                                             source: clip.image;
                                             width: 80px;
                                             height: 54px;
                                             image-fit: contain;
                                         }
                                         
                                         VerticalLayout {
                                             alignment: center;
                                             
                                             // Preview text/snippet content
                                             Text {
                                                 text: clip.preview;
                                                 font-size: 13px;
                                                 color: text-color;
                                                 overflow: elide;
                                                 max-height: 34px;
                                             }
     
                                             Text {
                                                 text: clip.timestamp_str;
                                                 font-size: 10px;
                                                 color: text-secondary;
                                             }
                                         }
                                        
                                        // Row Action buttons (Pin & Delete)
                                        VerticalLayout {
                                            alignment: center;
                                            HorizontalLayout {
                                                alignment: end;
                                                spacing: 6px;
                                                width: 50px;
                                                
                                                // Pin Button
                                                TouchArea {
                                                    width: 20px;
                                                    height: 20px;
                                                    clicked => { root.toggle-pin(clip.id); }
                                                    Text {
                                                        text: clip.pinned ? "📌" : "📍";
                                                        font-size: 12px;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
    
                                                // Delete Button
                                                TouchArea {
                                                    width: 20px;
                                                    height: 20px;
                                                    clicked => { root.delete-item(clip.id); }
                                                    Text {
                                                        text: "❌";
                                                        font-size: 10px;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if (active-tab == 1) : VerticalLayout {
                    spacing: 8px;
                    
                    // Categories Bar
                    HorizontalLayout {
                        height: 36px;
                        spacing: 4px;
                        padding-left: 6px;
                        padding-right: 6px;
                        alignment: center;
                        
                        // Category 0: Smileys
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 0; root.emoji-category-changed(0); }
                            Rectangle {
                                background: root.active-emoji-category == 0 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 0 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "😀";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 1: People
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 1; root.emoji-category-changed(1); }
                            Rectangle {
                                background: root.active-emoji-category == 1 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 1 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "👋";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 2: Animals
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 2; root.emoji-category-changed(2); }
                            Rectangle {
                                background: root.active-emoji-category == 2 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 2 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "🐱";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 3: Food
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 3; root.emoji-category-changed(3); }
                            Rectangle {
                                background: root.active-emoji-category == 3 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 3 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "🍔";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 4: Activities
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 4; root.emoji-category-changed(4); }
                            Rectangle {
                                background: root.active-emoji-category == 4 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 4 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "⚽";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 5: Travel
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 5; root.emoji-category-changed(5); }
                            Rectangle {
                                background: root.active-emoji-category == 5 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 5 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "✈️";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 6: Objects
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 6; root.emoji-category-changed(6); }
                            Rectangle {
                                background: root.active-emoji-category == 6 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 6 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "💡";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 7: Symbols
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 7; root.emoji-category-changed(7); }
                            Rectangle {
                                background: root.active-emoji-category == 7 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 7 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "❤️";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        // Category 8: Flags
                        TouchArea {
                            width: 32px;
                            height: 32px;
                            clicked => { root.active-emoji-category = 8; root.emoji-category-changed(8); }
                            Rectangle {
                                background: root.active-emoji-category == 8 ? card-hover-bg : transparent;
                                border-radius: 6px;
                                border-width: root.active-emoji-category == 8 ? 1px : 0px;
                                border-color: accent-color;
                                Text {
                                    text: "🏁";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    
                    ScrollView {
                        viewport-height: emoji_rows.length * 52px;
                        
                        VerticalLayout {
                            padding: 8px;
                            spacing: 8px;
                            alignment: start;
                            
                            for row in emoji_rows : HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                
                                for emoji in row.cols : TouchArea {
                                    width: 44px;
                                    height: 44px;
                                    clicked => {
                                        root.record-emoji(emoji.character);
                                    }
                                    
                                    Rectangle {
                                        background: parent.has-hover ? card-hover-bg : card-bg;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: border-color;
                                        
                                        Text {
                                            text: emoji.character;
                                            font-size: 20px;
                                            font-family: "Noto Color Emoji";
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if (active-tab == 2) : VerticalLayout {
                    spacing: 12px;
                    padding: 8px;
                    alignment: start;

                    Text {
                        text: "⚙️ Preferences";
                        font-size: 14px;
                        font-weight: 700;
                        color: text-color;
                    }

                    // Theme selector container
                    Rectangle {
                        background: card-bg;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: border-color;
                        
                        VerticalLayout {
                            padding: 12px;
                            spacing: 10px;

                            HorizontalLayout {
                                alignment: space-between;
                                
                                VerticalLayout {
                                    spacing: 2px;
                                    Text {
                                        text: "App Theme";
                                        font-size: 13px;
                                        font-weight: 600;
                                        color: text-color;
                                    }
                                    Text {
                                        text: "Choose your preferred color theme mode.";
                                        font-size: 11px;
                                        color: text-secondary;
                                    }
                                }
                            }

                            // Theme button group
                            HorizontalLayout {
                                spacing: 8px;
                                height: 32px;
                                
                                // Auto (System)
                                TouchArea {
                                    clicked => { root.change-theme("system"); }
                                    Rectangle {
                                        background: root.theme-mode == "system" ? accent-color : card-hover-bg;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: root.theme-mode == "system" ? accent-color : border-color;
                                        Text {
                                            text: "💻 Auto";
                                            color: root.theme-mode == "system" ? #ffffff : text-color;
                                            font-size: 12px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Dark
                                TouchArea {
                                    clicked => { root.change-theme("dark"); }
                                    Rectangle {
                                        background: root.theme-mode == "dark" ? accent-color : card-hover-bg;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: root.theme-mode == "dark" ? accent-color : border-color;
                                        Text {
                                            text: "🌙 Dark";
                                            color: root.theme-mode == "dark" ? #ffffff : text-color;
                                            font-size: 12px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                // Light
                                TouchArea {
                                    clicked => { root.change-theme("light"); }
                                    Rectangle {
                                        background: root.theme-mode == "light" ? accent-color : card-hover-bg;
                                        border-radius: 6px;
                                        border-width: 1px;
                                        border-color: root.theme-mode == "light" ? accent-color : border-color;
                                        Text {
                                            text: "☀️ Light";
                                            color: root.theme-mode == "light" ? #ffffff : text-color;
                                            font-size: 12px;
                                            font-weight: 600;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

