// linux-clipboard Slint UI file
// Implements the layout, visual styling, tabs, search, and action callbacks.

import { ScrollView } from "std-widgets.slint";

export struct SlintClipItem {
    id: string,
    item_type: string,    // "Text", "RichText", "Image"
    plain_text: string,
    timestamp_str: string,
    pinned: bool,
    preview: string,
    image_base64: string, // Only loaded if type is Image
    image: image,
}

export struct SlintEmojiItem {
    character: string,
    description: string,
}

export struct SlintEmojiRow {
    cols: [SlintEmojiItem],
}

export component AppWindow inherits Window {
    // Window properties
    title: "Clipboard History";
    width: 360px;
    height: 480px;
    always-on-top: true;
    background: transparent;
    no-frame: true;

    // Callbacks to Rust backend
    callback paste-item(string);         // item ID
    callback delete-item(string);        // item ID
    callback toggle-pin(string);         // item ID
    callback clear-history();
    callback record-emoji(string);       // emoji char
    callback search-changed(string);     // search text
    callback open-settings();
    callback close-window();
    callback check-shortcuts();
    callback fix-shortcuts();
    callback finish-setup();

    // Data models populated by Rust
    in-out property <[SlintClipItem]> clips: [];
    in-out property <[SlintEmojiRow]> emoji_rows: [];
    in-out property <int> selected_index: 0;
    in-out property <int> active-tab: 0; // 0 = Clips, 1 = Emojis, 2 = GIFs/Kaomojis
    in-out property <bool> is-dark: true;
    in-out property <bool> show-setup: false;
    in-out property <int> setup-step: 0; // 0 = Welcome, 1 = Detect/Conflict, 2 = Manual Setup
    in-out property <string> shortcut-status: "detecting"; // "detecting", "conflict", "ok", "failed"
    in-out property <string> shortcut-details: "";
    in-out property <string> search-placeholder: "Search clipboard...";


    // Dynamic coloring tokens
    property <color> bg-color: is-dark ? #202020 : #f3f3f3;
    property <color> border-color: is-dark ? #303030 : #e0e0e0;
    property <color> text-color: is-dark ? #ffffff : #1c1c1c;
    property <color> text-secondary: is-dark ? #aaaaaa : #666666;
    property <color> accent-color: #0078d4; // Windows Blue accent
    property <color> card-bg: is-dark ? #2d2d2d : #ffffff;
    property <color> card-hover-bg: is-dark ? #3d3d3d : #f9f9f9;

    // Main layout container with rounded border
    FocusScope {
        width: 100%;
        height: 100%;
        
        Rectangle {
            width: 100%;
            height: 100%;
            background: bg-color;
            border-radius: 12px;
            border-width: 1px;
            border-color: border-color;
            clip: true;

            if (show-setup) : VerticalLayout {
                padding: 18px;
                spacing: 16px;
                alignment: center;
                
                Text {
                    text: "Linux Clipboard Setup";
                    font-size: 18px;
                    font-weight: 700;
                    color: text-color;
                    horizontal-alignment: center;
                }

                // SCREEN 0: Welcome & Initial Detect
                if (setup-step == 0) : VerticalLayout {
                    spacing: 14px;
                    Text {
                        text: "Configure global hotkeys so you can access your clipboard history instantly at any time.";
                        font-size: 12px;
                        color: text-secondary;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Default Hotkey: Super + V";
                        font-size: 13px;
                        font-weight: 600;
                        color: accent-color;
                        horizontal-alignment: center;
                    }
                    TouchArea {
                        height: 38px;
                        clicked => {
                            root.check-shortcuts();
                        }
                        Rectangle {
                            background: accent-color;
                            border-radius: 6px;
                            Text {
                                text: "Check Hotkey Availability";
                                color: #ffffff;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // SCREEN 1: Checking, Conflict, or Success Details
                if (setup-step == 1) : VerticalLayout {
                    spacing: 14px;
                    
                    if (shortcut-status == "checking") : VerticalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text {
                            text: "Scanning system shortcuts...";
                            font-size: 13px;
                            color: text-color;
                            horizontal-alignment: center;
                        }
                    }

                    if (shortcut-status == "conflict") : VerticalLayout {
                        spacing: 12px;
                        Text {
                            text: "⚠️ Hotkey Conflict Detected!";
                            font-size: 13px;
                            font-weight: 600;
                            color: #d83b01; // Red warning color
                            horizontal-alignment: center;
                        }
                        Rectangle {
                            background: card-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: border-color;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: "Super+V is currently registered to:";
                                    font-size: 11px;
                                    color: text-secondary;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: shortcut-details;
                                    font-size: 12px;
                                    font-weight: 700;
                                    color: text-color;
                                    horizontal-alignment: center;
                                    wrap: word-wrap;
                                }
                            }
                        }
                        Text {
                            text: "Clicking 'Resolve & Fix' will disable the conflicting shortcut and bind Super+V to Linux Clipboard.";
                            font-size: 11px;
                            color: text-secondary;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                        }
                        TouchArea {
                            height: 38px;
                            clicked => {
                                root.fix-shortcuts();
                            }
                            Rectangle {
                                background: accent-color;
                                border-radius: 6px;
                                Text {
                                    text: "Resolve & Fix Shortcut";
                                    color: #ffffff;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    if (shortcut-status == "ok") : VerticalLayout {
                        spacing: 12px;
                        Text {
                            text: "✓ Hotkeys Configured Successfully!";
                            font-size: 13px;
                            font-weight: 600;
                            color: #107c41; // Green color
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Super + V is now active for Clipboard History.\nSuper + . is active for Emojis.";
                            font-size: 12px;
                            color: text-secondary;
                            horizontal-alignment: center;
                        }
                        TouchArea {
                            height: 38px;
                            clicked => {
                                root.finish-setup();
                            }
                            Rectangle {
                                background: #107c41;
                                border-radius: 6px;
                                Text {
                                    text: "Start Using Clipboard";
                                    color: #ffffff;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    if (shortcut-status == "failed") : VerticalLayout {
                        spacing: 12px;
                        Text {
                            text: "❌ Auto-configuration Failed";
                            font-size: 13px;
                            font-weight: 600;
                            color: #d83b01;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "We could not automatically bind the hotkeys on your current desktop configuration.";
                            font-size: 12px;
                            color: text-secondary;
                            wrap: word-wrap;
                            horizontal-alignment: center;
                        }
                        TouchArea {
                            height: 38px;
                            clicked => {
                                setup-step = 2;
                            }
                            Rectangle {
                                background: accent-color;
                                border-radius: 6px;
                                Text {
                                    text: "Show Manual Setup Guide";
                                    color: #ffffff;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // SCREEN 2: Manual Instructions
                if (setup-step == 2) : VerticalLayout {
                    spacing: 12px;
                    Text {
                        text: "Manual Hotkey Configuration";
                        font-size: 13px;
                        font-weight: 600;
                        color: text-color;
                        horizontal-alignment: center;
                    }
                    Rectangle {
                        background: card-bg;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: border-color;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;
                            Text {
                                text: "1. Open your desktop Settings -> Keyboard Shortcuts.";
                                font-size: 11px;
                                color: text-color;
                            }
                            Text {
                                text: "2. Add a Custom Shortcut:";
                                font-size: 11px;
                                color: text-color;
                                font-weight: 600;
                            }
                            Text {
                                text: "   • Name: Linux Clipboard\n   • Command: linux-clipboard\n   • Shortcut: Super + V";
                                font-size: 11px;
                                color: text-color;
                            }
                        }
                    }
                    TouchArea {
                        height: 38px;
                        clicked => {
                            root.finish-setup();
                        }
                        Rectangle {
                            background: accent-color;
                            border-radius: 6px;
                            Text {
                                text: "Completed - Open Clipboard";
                                color: #ffffff;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            if (!show-setup) : VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Header section
                HorizontalLayout {
                    alignment: space-between;
                    
                    Text {
                        text: "Clipboard";
                        font-size: 16px;
                        font-weight: 700;
                        color: text-color;
                        vertical-alignment: center;
                    }
                    
                    HorizontalLayout {
                        spacing: 8px;
                        
                        // Clear All button
                        TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.clear-history(); }
                            
                            Rectangle {
                                background: parent.has-hover ? card-hover-bg : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "🗑️";
                                    font-size: 13px;
                                    color: text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Settings Button
                        TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.open-settings(); }
                            
                            Rectangle {
                                background: parent.has-hover ? card-hover-bg : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "⚙️";
                                    font-size: 13px;
                                    color: text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        // Close button
                        close-btn := TouchArea {
                            width: 24px;
                            height: 24px;
                            clicked => { root.close-window(); }
                            
                            Rectangle {
                                background: close-btn.has-hover ? #e81123 : transparent;
                                border-radius: 4px;
                                Text {
                                    text: "✕";
                                    font-size: 12px;
                                    color: close-btn.has-hover ? #ffffff : text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Tab Switcher Bar
                HorizontalLayout {
                    height: 36px;
                    spacing: 4px;
                    
                    // Tab 1: Clipboard
                    TouchArea {
                        clicked => { active-tab = 0; search-placeholder = "Search clipboard..."; }
                        Rectangle {
                            background: active-tab == 0 ? card-bg : transparent;
                            border-radius: 6px;
                            border-width: active-tab == 0 ? 1px : 0px;
                            border-color: border-color;
                            Text {
                                text: "📋 Clips";
                                font-weight: active-tab == 0 ? 600 : 400;
                                color: active-tab == 0 ? accent-color : text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Tab 2: Emojis
                    TouchArea {
                        clicked => { active-tab = 1; search-placeholder = "Search emojis..."; }
                        Rectangle {
                            background: active-tab == 1 ? card-bg : transparent;
                            border-radius: 6px;
                            border-width: active-tab == 1 ? 1px : 0px;
                            border-color: border-color;
                            Text {
                                text: "😊 Emojis";
                                font-weight: active-tab == 1 ? 600 : 400;
                                color: active-tab == 1 ? accent-color : text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Search Bar Container
                Rectangle {
                    height: 36px;
                    background: card-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: border-color;
                    
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        alignment: stretch;
                        
                        search-input := TextInput {
                            font-size: 13px;
                            color: text-color;
                            single-line: true;
                            vertical-alignment: center;
                            
                            init => { self.focus(); }
                            
                            // Connect input edits back to search filter
                            edited => { root.search-changed(self.text); }
                            
                            // Intercept arrow keys and enter
                            key-pressed(event) => {
                                if (event.text == Key.DownArrow) {
                                    root.selected_index = Math.min(root.selected_index + 1, root.clips.length - 1);
                                    return accept;
                                }
                                if (event.text == Key.UpArrow) {
                                    root.selected_index = Math.max(root.selected_index - 1, 0);
                                    return accept;
                                }
                                if (event.text == Key.Return) {
                                    if (root.clips.length > 0 && root.selected_index >= 0 && root.selected_index < root.clips.length) {
                                        root.paste-item(root.clips[root.selected_index].id);
                                    }
                                    return accept;
                                }
                                reject
                            }
                            
                            // Placeholder Text
                            if (self.text == "") : Text {
                                text: search-placeholder;
                                font-size: 13px;
                                color: text-secondary;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
 
                 // Main tab layouts viewport
                 if (active-tab == 0) : ScrollView {
                     viewport-height: clips.length * 76px;
                     
                     VerticalLayout {
                         spacing: 6px;
                         padding-right: 4px;
                         
                         for clip[idx] in clips : TouchArea {
                             height: 70px;
                             clicked => { root.paste-item(clip.id); }
 
                             Rectangle {
                                 background: (root.selected_index == idx) ? card-hover-bg : (parent.has-hover ? card-hover-bg : card-bg);
                                 border-radius: 8px;
                                 border-width: (root.selected_index == idx || clip.pinned) ? 1.5px : 1px;
                                 border-color: (root.selected_index == idx) ? accent-color : (clip.pinned ? accent-color : border-color);
                                 
                                 HorizontalLayout {
                                     padding: 8px;
                                     spacing: 8px;
                                     
                                     if (clip.item_type == "Image") : Image {
                                         source: clip.image;
                                         width: 80px;
                                         height: 54px;
                                         image-fit: contain;
                                     }
                                     
                                     VerticalLayout {
                                         alignment: center;
                                         
                                         // Preview text/snippet content
                                         Text {
                                             text: clip.preview;
                                             font-size: 13px;
                                             color: text-color;
                                             overflow: elide;
                                             max-height: 34px;
                                         }
 
                                         Text {
                                             text: clip.timestamp_str;
                                             font-size: 10px;
                                             color: text-secondary;
                                         }
                                     }
                                    
                                    // Row Action buttons (Pin & Delete)
                                    VerticalLayout {
                                        alignment: center;
                                        HorizontalLayout {
                                            alignment: end;
                                            spacing: 6px;
                                            width: 50px;
                                            
                                            // Pin Button
                                            TouchArea {
                                                width: 20px;
                                                height: 20px;
                                                clicked => { root.toggle-pin(clip.id); }
                                                Text {
                                                    text: clip.pinned ? "📌" : "📍";
                                                    font-size: 12px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }

                                            // Delete Button
                                            TouchArea {
                                                width: 20px;
                                                height: 20px;
                                                clicked => { root.delete-item(clip.id); }
                                                Text {
                                                    text: "❌";
                                                    font-size: 10px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if (active-tab == 1) : ScrollView {
                    viewport-height: emoji_rows.length * 52px;
                    
                    VerticalLayout {
                        padding: 8px;
                        spacing: 8px;
                        alignment: start;
                        
                        for row in emoji_rows : HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            
                            for emoji in row.cols : TouchArea {
                                width: 44px;
                                height: 44px;
                                clicked => {
                                    root.record-emoji(emoji.character);
                                }
                                
                                Rectangle {
                                    background: parent.has-hover ? card-hover-bg : card-bg;
                                    border-radius: 6px;
                                    border-width: 1px;
                                    border-color: border-color;
                                    
                                    Text {
                                        text: emoji.character;
                                        font-size: 20px;
                                        font-family: "Noto Color Emoji";
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

